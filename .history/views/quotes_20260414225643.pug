doctype html
html
  head
    title Quotes
    link(rel="stylesheet", href="/style.css")

  body

    include partials/header

    h1 All Motivational Quotes 💬

    .grid
      each q in quotes
        .cardQuotes
          h3= q.text
          p.author= "- " + (q.author || "Unknown")

   

    include partials/footer