doctype html
html
  head
    title Workout Details
    link(rel="stylesheet", href="/style.css")

  body
    include partials/header

    h1= category + " Workouts"

    .grid
      if exercises && exercises.length > 0
        each ex in exercises
          .card
           - var name = "No name"
               if ex.translations && ex.translations.length > 0 && ex.translations[0].name
           - name = ex.translations[0].name

                h3= name
            if ex.images && ex.images.length > 0
              img(src=ex.images[0].image)

            if ex.translations && ex.translations.length > 0
              p!= ex.translations[0].description
      else
        p No exercises found

    include partials/footer