doctype html
html
  head
    title Workouts
    link(rel="stylesheet", href="/style.css")

  body
    include partials/header

    h1= category

    .grid
      each ex in exercises
        .card
          if ex.images && ex.images.length > 0
            img(src=ex.images[0].image)

          h3= ex.translations && ex.translations.length > 0 
            ? ex.translations[0].name 
            : "No name"

    include partials/footer
