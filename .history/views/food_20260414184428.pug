extends layout

block content
  h1 workout Search

  form(method="POST")
  input(type="text" name="search" placeholder="Search workout")
  button Search

  if data
    each item in data
      div.card
        h3= item.product_name
        p Calories: #{item.nutriments?.['energy-kcal_100g'] || 0}

        form(method="POST" action="/workout/add")
          input(type="hidden" name="name" value=item.product_name)
          input(type="hidden" name="calories" value=item.nutriments?.['energy-kcal_100g'] || 0)
          button Add